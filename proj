void show_main_menu() {
    printf("\n╔════════════════════════════════════════╗\n");
    printf("║   INVENTORY MANAGEMENT SYSTEM          ║\n");
    printf("╠════════════════════════════════════════╣\n");
    printf("║  1. Register New Account               ║\n");
    printf("║  2. Login to Account                   ║\n");
    printf("║  3. View All Transactions (Admin)      ║\n");
    printf("║  4. Exit                               ║\n");
    printf("╚════════════════════════════════════════╝\n");
    printf("Enter your choice (1-4): ");
}

void show_user_menu() {
    printf("\n╔════════════════════════════════════════╗\n");
    printf("║       USER MENU                       ║\n");
    printf("╠════════════════════════════════════════╣\n");
    printf("║  1. Shop & Add to Cart                 ║\n");
    printf("║  2. View Shopping Cart                 ║\n");
    printf("║  3. Checkout                           ║\n");
    printf("║  4. View My Transactions               ║\n");
    printf("║  5. Logout                             ║\n");
    printf("╚════════════════════════════════════════╝\n");
    printf("Enter your choice (1-5): ");
}

int main() {
    int choice;

    // Initialize inventory file if it doesn't exist
    initialize_inventory_file();
    load_inventory();

    while(1) {
        if(strlen(current_user) == 0) {
            // Main menu (not logged in)
            show_main_menu();
            scanf("%d", &choice);

            switch(choice) {
                case 1:
                    register_user();
                    break;

                case 2:
                    if(authenticate_user()) {
                        // User menu
                        int user_choice;
                        while(1) {
                            show_user_menu();
                            scanf("%d", &user_choice);

                            switch(user_choice) {
                                case 1:
                                    load_inventory();
                                    add_to_cart();
                                    break;

                                case 2:
                                    display_cart();
                                    break;

                                case 3:
                                    checkout();
                                    break;

                                case 4:
                                    view_transaction_history(current_user);
                                    break;

                                case 5:
                                    printf("\n[INFO] Logging out...\n");
                                    strcpy(current_user, "");
                                    break;

                                default:
                                    printf("\n[ERROR] Invalid choice! Please enter 1-5.\n");
                            }

                            if(strlen(current_user) == 0) {
                                break;
                            }
                        }
                    }
                    break;

                case 3:
                    view_all_transactions();
                    break;

                case 4:
                    printf("\nThank you for using the system. Goodbye!\n");
                    return 0;

                default:
                    printf("\n[ERROR] Invalid choice! Please enter 1-4.\n");
            }
        }
    }

    return 0;
}
